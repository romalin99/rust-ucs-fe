# Generated by Cargo
# 编译产物和可执行文件
/target/
debug/
release/

# Rustfmt 备份文件
**/*.rs.bk

# 依赖锁文件（二进制 crate 通常提交，库 crate 通常不提交）
# Cargo.lock

# ==================== 环境变量（敏感信息） ====================
.env
.env.local
.env.*.local
.env*.local

# ==================== IDE / 编辑器配置 ====================
.idea/
.vscode/
*.swp
*.swo
*.swn
*~

# ==================== 操作系统临时文件 ====================
.DS_Store
Thumbs.db
Desktop.ini

# ==================== 日志和临时文件 ====================
logs/
*.log
*.out

# ==================== 测试覆盖率报告 ====================
coverage/
lcov.info
htmlcov/
*.profraw
*.profdata

# ==================== 发布 / 打包产物 ====================
dist/
build/
out/
*.tar.gz
*.zip

# ==================== 项目特定配置 ====================
config/local.toml
config/*.local.toml

# ==================== 缓存和临时目录 ====================
.cache/
tmp/
temp/

# ==================== Docker / 容器相关 ====================
.docker/
.dockerignore
.docker/

# ==================== Profiling / 性能分析 ====================
perf.data*
criterion/
flamegraph.svg
*.perf

# ==================== 生成的代码 ====================
*.pb.rs
*.rs.bk
# protobuf 等工具生成的代码（如果有其他生成器，可继续添加）

# ==================== 其他常见忽略 ====================
# Cargo 临时文件
**/.cargo-ok
Cargo.lock

# 文档生成
doc/
target/doc/

# 如果使用 wasm / web 相关
pkg/
wasm-pack.log

*.pdb

**/mutants.out*/
